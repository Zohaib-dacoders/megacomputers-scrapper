# --- NocoDB (self-hosted) ---
# Create a base in the NocoDB UI; the scraper creates the tables inside it.
NOCODB_BASE_URL=https://anchor.dacoders.com
NOCODB_API_TOKEN=
NOCODB_BASE_ID=

# --- FlareSolverr (Cloudflare bypass) ---
# zahcomputers.pk sits behind a Cloudflare JS challenge. FlareSolverr runs an
# undetected-chromedriver in Docker, solves the challenge, and returns cookies
# the scraper can replay on plain httpx requests. URL must be reachable from
# wherever the scraper runs (local dev, GitHub Actions runner, etc.).
FLARESOLVERR_URL=
CF_COOKIE_CACHE_PATH=.cf-cookies.json
CF_SESSION_TTL_SECONDS=3600

# --- Scraper ---
SITEMAP_URL=https://zahcomputers.pk/sitemap_index.xml
SITE_ORIGIN=https://zahcomputers.pk/
CONCURRENCY=2
REQUEST_DELAY_MS=1500
RESCRAPE_AFTER_HOURS=12      # skip products scraped more recently than this
FORCE_RESCRAPE=false         # true = ignore the skip window, re-scrape everything
SCRAPE_LIMIT=0               # 0 = scrape every URL; >0 = sample N URLs (smoke test)
