# ZAH scraper — Coolify env template. Set REAL values in Coolify → Environment
# Variables. Postgres-only (NocoDB is no longer used). Hosts are reachable by
# CONTAINER NAME on the `coolify` docker network.

# --- Postgres (same pricesync DB the dashboard uses) ---
QUEUE_DSN=postgresql://postgres:CHANGEME@yv1n67vj3detg21zejapd0z9:5432/pricesync
# base key = the ZAH base → writes land in zah_* tables (pgdb prefix selector)
NOCODB_BASE_ID=pl1dzby064y3coj
ZAH_BASE_ID=pl1dzby064y3coj
MC_BASE_ID=pr1f191l3pjr0d4

# --- FlareSolverr (Cloudflare bypass — existing container on this server) ---
FLARESOLVERR_URL=http://v1kvvik5a52gp30gnu6w7kge.159.195.139.150.sslip.io
CF_SESSION_TTL_SECONDS=3600

# --- Outbound proxy pool (Webshare-style, comma-separated) ---
OUTBOUND_PROXY_URLS=http://user:pass@ip:port,http://user:pass@ip:port

# --- Scraper target + politeness knobs (defaults are fine) ---
SITEMAP_URL=https://zahcomputers.pk/sitemap_index.xml
SITE_ORIGIN=https://zahcomputers.pk/
CONCURRENCY=2
REQUEST_DELAY_MS=1500
REQUEST_TIMEOUT=30
RESCRAPE_AFTER_HOURS=12      # skip products scraped more recently than this
FORCE_RESCRAPE=false         # true = ignore the skip window, re-scrape everything
SCRAPE_LIMIT=0               # 0 = scrape every URL; >0 = sample N (smoke test)
